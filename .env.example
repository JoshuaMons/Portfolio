## =========================
## Portfolio env vars (copy to .env.local locally OR Vercel Env Vars)
## =========================
##
## Where to set them:
## - Local dev: create `C:\Users\Josh\portfolio\.env.local` (NOT committed)
## - Vercel: Project -> Settings -> Environment Variables (Production + Preview)
##
## Supabase locations:
## - Project URL + anon/publishable key:
##   Supabase -> Project Settings -> API
## - User IDs (UUID):
##   Supabase -> Authentication -> Users
##
## IMPORTANT:
## - Never commit real secrets to GitHub
## - Never put secret keys in NEXT_PUBLIC_*

# 1) Supabase Project URL (looks like: https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# 2) Supabase "anon" / "publishable" API key (safe for browser when RLS is enabled)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used by the app to gate /admin access (set to your Supabase auth user id)
# 3) Your admin user's UUID (Authentication -> Users -> copy UID)
ADMIN_USER_ID=

# Teacher login (set to Supabase auth user id of the teacher account)
# 4) Teacher user's UUID (Authentication -> Users -> copy UID)
TEACHER_USER_ID=

# Server-only (do NOT expose in browser)
# 5) Supabase service_role key (Project Settings -> API -> service_role SECRET)
SUPABASE_SERVICE_ROLE_KEY=

# Email sending (Resend)
# 6) Resend API key (Resend dashboard)
RESEND_API_KEY=

# Fallback recipient if profile contact_email is empty
# If you didn't set contact email in /admin/profile yet, use this as fallback.
ADMIN_EMAIL=

